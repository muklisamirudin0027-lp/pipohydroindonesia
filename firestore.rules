rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global safety net: deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getUserData().role == 'admin';
    }

    // Users Collection rules
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Allow user creation for own profile; restrict role to 'petani' unless special admin email
      allow create: if isOwner(userId) && (
        request.resource.data.role == 'petani' || 
        request.auth.token.email == 'admin@pipohydro.com'
      );
      
      // Allow updates if role remains unchanged, or if updater is admin or has admin email
      allow update: if isOwner(userId) && (
        request.resource.data.role == resource.data.role || 
        isAdmin() || 
        request.auth.token.email == 'admin@pipohydro.com'
      );
      
      allow delete: if isAdmin();
    }

    // Website Content Collection rules
    match /website_content/{documentId} {
      allow read: if true; // Anyone can read website content for the landing page
      allow write: if isAdmin(); // Only verified admins can write website content
    }
  }
}
